# OJT AI Journal Report Generator - Environment Configuration
# Copy this file to .env and fill in your API keys

# ==================== Database ====================
DB_PATH=storage/db/journal.db

# ==================== Upload Configuration ====================
UPLOAD_DIR=storage/uploads/
MAX_FILE_SIZE=5242880
ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp

# ==================== Primary AI API (OpenRouter) ====================
# Get your key from https://openrouter.ai/keys
QWEN_API_KEY=your_openrouter_api_key_here
QWEN_API_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
QWEN_VISION_MODEL=qwen/qwen-2-vl-7b-instruct
QWEN_TEXT_MODEL=qwen/qwen-2.5-72b-instruct

# ==================== Fallback AI Models (Free) ====================
FALLBACK_VISION_MODEL=google/gemini-2.0-flash-exp:free
FALLBACK_TEXT_MODEL=google/gemini-2.0-flash-exp:free

# ==================== Google Gemini API (Free Tier) ====================
# Get your key from https://aistudio.google.com/app/apikey
# Free: 60 requests/minute, 1500/day
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_MODEL=gemini-2.0-flash-exp

# ==================== Groq API (Free Tier - Fast) ====================
# Get your key from https://console.groq.com
# Currently free during beta
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_ENDPOINT=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile

# ==================== AI Configuration ====================
AI_MAX_RETRIES=1
AI_TIMEOUT=30

# ==================== Agent Configuration ====================
AGENT_MAX_STEPS=10
AGENT_TEMPERATURE=0.7
