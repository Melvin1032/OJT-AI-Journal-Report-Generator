# Environment files (contains API keys and secrets)
.env
config/.env
config/.env.local
config/.env.*.local

# Storage directories (user data and sensitive files)
storage/uploads/*
!storage/uploads/.gitkeep
storage/cache/*
!storage/cache/.gitkeep
storage/logs/*
!storage/logs/.gitkeep
storage/db/*.db
storage/db/*.db-journal
storage/db/*.db-shm
storage/db/*.db-wal

# Logs
*.log
php_errors.log

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp

# Composer dependencies (if using Composer)
/vendor/

# Node modules (if using npm/yarn)
node_modules/
package-lock.json
yarn.lock
