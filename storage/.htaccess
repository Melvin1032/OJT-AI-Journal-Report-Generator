# Protect sensitive files in storage directory

# Block access to encryption key
<Files ".encryption_key">
    Order allow,deny
    Deny from all
</Files>

# Block access to database files
<FilesMatch "\.db$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to log files
<FilesMatch "\.log$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to cache files (but NOT in uploads subdirectory)
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Allow uploads directory
    RewriteCond %{REQUEST_URI} !^/storage/uploads/
    # Block cache files
    RewriteCond %{REQUEST_URI} ^/storage/cache/
    RewriteRule .* - [F,L]
</IfModule>
